};

const navPages = [
  { href: '/',                     label: 'Inicio' },
  { href: '/servicios',            label: 'Servicios' },
  { href: '/retiros',              label: 'Retiros' },
  { href: '/galeria',              label: 'Galería' },
  { href: '/recursos',             label: 'Recursos' },
  { href: '/contacto',             label: 'Contacto' },
  { href: '/sobre-nosotros',       label: 'Nosotros' },
  { href: '/libro-reclamaciones',  label: 'Libro de Reclamaciones' },
];
---

<footer class="site-footer">
  <!-- Wave top -->
  <div class="footer-wave" aria-hidden="true">
    <svg viewBox="0 0 1200 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 80 L0 40 Q300 0 600 40 Q900 80 1200 40 L1200 80 Z" fill="var(--color-jungle-deep)"/>
    </svg>
  </div>

  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Brand column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="Ayahuasca Cusco">
            <img src="/logo.png" alt="Ayahuasca Cusco Logo" class="logo-img-footer" width="48" height="48" />
            <span class="logo-text">
              <span class="logo-title">Ayahuasca</span>
              <span class="logo-sub">Cusco</span>
            </span>
          </a>
          <p class="footer-tagline">
            Guardianes de la medicina ancestral amazónica. Ceremonias de ayahuasca auténticas con facilitadores certificados.
          </p>

          <!-- Social links -->
          <div class="social-links" aria-label="Redes sociales">
            {socials.map(({ name, href, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class={`social-link social-link--${icon}`}
                aria-label={name}
                title={name}
              >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="18" height="18">
                  <Fragment set:html={svgIcons[icon] ?? ''} />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Pages column -->
        <div class="footer-col">
          <h3 class="footer-col-title">Páginas</h3>
          <ul class="footer-links">
            {navPages.map(({ href, label }) => (
              <li><a href={href} class="footer-link">{label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Contact column -->
        <div class="footer-col">
          <h3 class="footer-col-title">Contacto</h3>
          <ul class="footer-contact-list">
            <li>
              <span class="contact-icon" aria-hidden="true">📍</span>
              <span>Cusco, Cusco, Perú</span>
            </li>
            <li>
              <span class="contact-icon" aria-hidden="true">📞</span>
              <a href="tel:+51999999999" class="footer-link">+51 999 999 999</a>
            </li>
            <li>
              <span class="contact-icon" aria-hidden="true">✉️</span>
              <a href="mailto:info@ayahuasca.com" class="footer-link">info@ayahuasca.com</a>
            </li>
            <li>
              <span class="contact-icon" aria-hidden="true">🕐</span>
              <span>Lun–Dom, 8:00–20:00</span>
            </li>
          </ul>

          <!-- Newsletter -->
          <div class="newsletter" aria-label="Suscribirse al boletín">
            <h4 class="footer-col-title" style="margin-top:1.5rem">Newsletter</h4>
            <form class="newsletter-form" aria-label="Formulario de suscripción" onsubmit="return false;">
              <input
                type="email"
                placeholder="Tu correo electrónico"
                class="newsletter-input"
                aria-label="Correo electrónico"
                required
              />
              <button type="submit" class="newsletter-btn" aria-label="Suscribirse">
                Suscribir
              </button>
            </form>
          </div>
        </div>

        <!-- Map column -->
        <div class="footer-col">
          <h3 class="footer-col-title">Encuéntranos</h3>
          <div class="footer-map-wrap">
            <iframe
              src="https://www.google.com/maps/embed?pb=!4v1773099467846!6m8!1m7!1shmjKGDB1pLO0KH2HdqSY0g!2m2!1d-13.52028816951927!2d-71.97846790079805!3f339.8172098725816!4f-27.507022524052772!5f0.7820865974627469" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
              width="100%"
              height="200"
              style="border:0;border-radius:8px;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación Spirit of Amazonas en Iquitos, Perú"
            ></iframe>
          </div>
          
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {year} Ayahuasca Cusco. Todos los derechos reservados.
      </p>
      <nav class="footer-legal" aria-label="Legal">
        <a href="/privacidad" class="footer-legal-link">Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/terminos" class="footer-legal-link">Términos</a>
        <span aria-hidden="true">·</span>
        <a href="/libro-reclamaciones" class="footer-legal-link">Reclamaciones</a>
      </nav>
      <p class="footer-langs" aria-label="Idiomas disponibles">
        <a href="/"    class="footer-lang-link">🇵🇪 Español</a>
        <a href="/en"  class="footer-lang-link">🇺🇸 English</a>
        <a href="/pt"  class="footer-lang-link">🇧🇷 Português</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-jungle-deep);
    color: rgba(255,255,255,0.75);
    margin-top: auto;
  }

  /* Wave */
  .footer-wave {
    line-height: 0;
    background: var(--color-cream);
  }
  .footer-wave svg { width: 100%; height: 60px; display: block; }

  .footer-main { padding: 4rem 0 2rem; }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr 1.5fr;
    gap: 3rem;
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }
  .logo-img-footer { border-radius: 50%; object-fit: contain; }
  .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
  .logo-title {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold-pale);
    font-family: var(--font-body);
  }
  .logo-sub {
    font-size: 1.15rem;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-white);
  }
  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* Social links */
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .social-link:hover { transform: translateY(-3px); color: #fff; }
  .social-link--facebook:hover  { background: #1877f2; }
  .social-link--instagram:hover { background: linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); }
  .social-link--youtube:hover   { background: #ff0000; }
  .social-link--tiktok:hover    { background: #010101; }
  .social-link--twitter:hover   { background: #000; }
  .social-link--pinterest:hover { background: #e60023; }
  .social-link--telegram:hover  { background: #0088cc; }
  .social-link--whatsapp:hover  { background: #25d366; }

  /* Column */
  .footer-col-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold-pale);
    margin-bottom: 1rem;
  }

  .footer-links { display: flex; flex-direction: column; gap: 0.4rem; }
  .footer-link {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s, padding-left 0.2s;
  }
  .footer-link:hover { color: var(--color-gold-light); padding-left: 4px; }

  /* Contact list */
  .footer-contact-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-contact-list li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.875rem; }
  .contact-icon { flex-shrink: 0; font-size: 1rem; }

  /* Newsletter */
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .newsletter-input {
    flex: 1;
    padding: 0.55rem 0.875rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.8rem;
  }
  .newsletter-input::placeholder { color: rgba(255,255,255,0.35); }
  .newsletter-input:focus { outline: none; border-color: var(--color-gold); }
  .newsletter-btn {
    padding: 0.55rem 1rem;
    background: var(--color-gold);
    color: var(--color-white);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .newsletter-btn:hover { background: var(--color-gold-light); }

  /* Map */
  .footer-map-wrap { border-radius: 8px; overflow: hidden; margin-bottom: 1rem; }

  /* WA button */
  .footer-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .footer-wa-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37,211,102,0.4);
    color: #fff;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1.25rem 0;
  }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-copy { font-size: 0.8rem; color: rgba(255,255,255,0.4); }
  .footer-legal { display: flex; align-items: center; gap: 0.5rem; }
  .footer-legal-link {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal-link:hover { color: var(--color-gold-light); }
  .footer-langs { display: flex; gap: 0.75rem; }
  .footer-lang-link {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-lang-link:hover { color: var(--color-gold-light); }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
