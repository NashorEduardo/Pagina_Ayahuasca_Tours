  @media (max-width: 900px) {
    .header-nav    { display: none; }
    .header-wa-btn { display: none; }
    .menu-toggle   { display: flex; }
    .mobile-menu   { display: block; }
  }

  @media (max-width: 520px) {
    .lang-switcher { display: none; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const menu   = document.getElementById('mobile-menu') as HTMLElement | null;

  // ── Mobile menu toggle ──────────────────────────────────────────────
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
  });

  // Close on any mobile link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });

  // ── Desktop dropdown (click + keyboard) ────────────────────────────
  const dropdownItems = document.querySelectorAll<HTMLElement>('.nav-item--has-submenu');

  dropdownItems.forEach(item => {
    const link = item.querySelector<HTMLAnchorElement>('a.nav-link');

    link?.addEventListener('click', (e) => {
      if (window.innerWidth <= 900) return; // let mobile handle it naturally
      e.preventDefault();
      const isActive = item.classList.contains('is-active');
      dropdownItems.forEach(other => other.classList.remove('is-active'));
      if (!isActive) item.classList.add('is-active');
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (window.innerWidth <= 900) return;
    const isInside = Array.from(dropdownItems).some(item => item.contains(e.target as Node));
    if (!isInside) dropdownItems.forEach(item => item.classList.remove('is-active'));
  });

  // Close on submenu link click
  document.querySelectorAll('.nav-submenu-link, .tour-link').forEach(link => {
    link.addEventListener('click', () => {
      dropdownItems.forEach(item => item.classList.remove('is-active'));
    });
  });
</script>