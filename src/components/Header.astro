---
// src/components/Header.astro
// Sticky header with navigation, language switcher and mobile menu

const currentPath = Astro.url.pathname;
const lang = currentPath.startsWith('/en') ? 'en' : currentPath.startsWith('/pt') ? 'pt' : 'es';

const navLinks = {
  es: [
    { href: '/',               label: 'Inicio' },
    { href: '/servicios',      label: 'Servicios' },
    { href: '/tours',          label: 'Tours' },
    { href: '/galeria',        label: 'Galería' },
    { href: '/recursos',       label: 'Recursos' },
    { href: '/contacto',       label: 'Contacto' },
    { href: '/sobre-nosotros', label: 'Nosotros' },
  ],
  en: [
    { href: '/en',             label: 'Home' },
    { href: '/en/services',    label: 'Services' },
    { href: '/en/tours',       label: 'Tours' },
    { href: '/en/gallery',     label: 'Gallery' },
    { href: '/en/faq',         label: 'FAQ' },
    { href: '/en/contact',     label: 'Contact' },
    { href: '/en/about',       label: 'About' },
  ],
  pt: [
    { href: '/pt',             label: 'Início' },
    { href: '/pt/servicos',    label: 'Serviços' },
    { href: '/pt/tours',       label: 'Tours' },
    { href: '/pt/galeria',     label: 'Galeria' },
    { href: '/pt/perguntas',   label: 'FAQ' },
    { href: '/pt/contato',     label: 'Contato' },
    { href: '/pt/sobre',       label: 'Sobre' },
  ],
};

const links = navLinks[lang as keyof typeof navLinks] ?? navLinks.es;

// ─── Tours dropdown (los 3 tours reales) ───────────────────────────────────
const toursMenu = [
  {
    href:    '/tours/killarumiyoc',
    label:   'Killarumiyoc',
    sub:     'Sitio arqueológico sagrado',
    icon:    '🌙',
    image:   '/img/menu/quillarumiyo.png',
  },
  {
    href:    '/tours/perolniyoc',
    label:   'Perolniyoc',
    sub:     'Cascada en las alturas',
    icon:    '💧',
    image:   '/img/menu/perolniyoc.png',
  },
  {
    href:    '/tours/ValleSagrado',
    label:   'Valle Sagrado',
    sub:     'Ruta inca por el valle',
    icon:    '🏔️',
    image:   '/img/menu/valle_sagrado.png',
  },
];

// ─── Recursos submenu ──────────────────────────────────────────────────────
const recursosSubmenu = [
  { href: '/recursos#testimonios', label: 'Testimonios' },
  { href: '/recursos#blog',        label: 'Blog' },
  { href: '/recursos#faq',         label: 'Preguntas Frecuentes' },
];

const langSwitcher = [
  { href: '/',    code: 'ES', label: 'Español' },
  { href: '/en',  code: 'EN', label: 'English' },
  { href: '/pt',  code: 'PT', label: 'Português' },
];
---

<header id="site-header" class="site-header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href={lang === 'es' ? '/' : `/${lang}`} class="header-logo" aria-label="Ayahuasca Cusco - Inicio">
      <img src="/logo.png" alt="Ayahuasca Cusco Logo" class="logo-img" />
      <span class="logo-text">
        <span class="logo-title">Ayahuasca</span>
        <span class="logo-sub">Cusco</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav id="main-nav" class="header-nav" aria-label="Navegación principal">
      <ul class="nav-list">
        {links.map(({ href, label }) => {
          const isToursLink     = lang === 'es' && href === '/tours';
          const isRecursosLink  = lang === 'es' && href === '/recursos';
          const isDropdown      = isToursLink || isRecursosLink;

          return (
            <li class:list={['nav-item', { 'nav-item--has-submenu': isDropdown }]}>
              <a
                href={href}
                class:list={['nav-link', { 'nav-link--active': currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
                aria-current={currentPath === href ? 'page' : undefined}
                aria-haspopup={isDropdown ? 'menu' : undefined}
              >
                {label}
                {isDropdown && <span class="nav-chevron" aria-hidden="true">›</span>}
              </a>

              {/* ── Tours dropdown ── */}
              {isToursLink && (
                <div class="nav-submenu tours-dropdown" role="menu" aria-label="Tours disponibles">
                  <div class="tours-dropdown-header">
                    <span class="tours-dropdown-eyebrow">Nuestros Tours</span>
                    <a href="/tours" class="tours-dropdown-all">Ver todos →</a>
                  </div>
                  <ul class="tours-list">
                    {toursMenu.map(tour => (
                      <li role="none" class="tour-item">
                        <a href={tour.href} class="tour-link" role="menuitem">
                          <div class="tour-img-wrap">
                            <img src={tour.image} alt={tour.label} class="tour-img" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <span class="tour-img-fallback" style="display:none">{tour.icon}</span>
                          </div>
                          <div class="tour-info">
                            <span class="tour-name">{tour.label}</span>
                            <span class="tour-sub">{tour.sub}</span>
                          </div>
                          <span class="tour-arrow" aria-hidden="true">→</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* ── Recursos dropdown ── */}
              {isRecursosLink && (
                <div class="nav-submenu recursos-dropdown" role="menu" aria-label="Submenú de Recursos">
                  <ul>
                    {recursosSubmenu.map(({ href: subHref, label: subLabel }) => (
                      <li role="none">
                        <a href={subHref} class="nav-submenu-link" role="menuitem">{subLabel}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Right controls -->
    <div class="header-controls">

      <!-- Language switcher -->
      <div class="lang-switcher" role="navigation" aria-label="Cambiar idioma">
        {langSwitcher.map(({ href, code, label }) => (
          <a
            href={href}
            class:list={['lang-btn', { 'lang-btn--active': lang === code.toLowerCase() }]}
            title={label}
            aria-label={`Cambiar a ${label}`}
          >
            {code}
          </a>
        ))}
      </div>

      <!-- Social icons -->
      <div class="header-socials">
        <a href="#" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M12 2.04c-5.5 0-10 4.48-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.67c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.54-4.5-10.02-10-10.02Z"/>
          </svg>
        </a>
        <a href="#" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.37.9.42.4.68.81.9 1.36.17.44.36 1.07.41 2.24.06 1.27.07 1.65.07 4.86s-.01 3.59-.07 4.86c-.05 1.17-.24 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.41.41-.81.67-1.37.89-.43.17-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.24-2.23-.41-.56-.22-.96-.48-1.37-.89-.42-.42-.68-.82-.9-1.38-.17-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.86s.01-3.59.07-4.86c.05-1.17.24-1.8.41-2.24.22-.55.48-.95.9-1.36.41-.42.81-.68 1.37-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07c-1.27.06-2.14.26-2.9.55-.78.3-1.44.7-2.1 1.36-.66.66-1.06 1.32-1.36 2.1-.3.76-.5 1.63-.55 2.9C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.14.55 2.9.3.78.7 1.44 1.36 2.1.66.66 1.32 1.06 2.1 1.36.76.3 1.63.5 2.9.55 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.14-.26 2.9-.55.78-.3 1.44-.7 2.1-1.36.66-.66 1.06-1.32 1.36-2.1.3-.76.5-1.63.55-2.9.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.14-.55-2.9-.3-.78-.7-1.44-1.36-2.1-.66-.66-1.32-1.06-2.1-1.36-.76-.3-1.63-.5-2.9-.55C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32A6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/>
          </svg>
        </a>
        <a href="#" class="social-link" aria-label="WhatsApp" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
        </a>
        <a href="#" class="social-link" aria-label="YouTube" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.377.55A3.016 3.016 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136C4.495 20.5 12 20.5 12 20.5s7.505 0 9.377-.55a3.016 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>

      <!-- WhatsApp CTA (desktop) -->
      <a
        href="https://wa.me/51999999999"
        target="_blank"
        rel="noopener noreferrer"
        class="header-wa-btn"
        aria-label="Contactar por WhatsApp"
      >
        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        WhatsApp
      </a>

      <!-- Hamburger -->
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>

  <!-- ─── Mobile menu ──────────────────────────────────────────────── -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Menú móvil">
      <ul class="mobile-nav-list">
        {links.map(({ href, label }) => {
          const isToursLink    = lang === 'es' && href === '/tours';
          const isRecursosLink = lang === 'es' && href === '/recursos';
          const isDropdown     = isToursLink || isRecursosLink;

          return (
            <li>
              <a href={href} class="mobile-nav-link">{label}</a>
              {isToursLink && (
                <ul class="mobile-submenu">
                  {toursMenu.map(tour => (
                    <li>
                      <a href={tour.href} class="mobile-submenu-link">
                        <span class="mobile-tour-icon" aria-hidden="true">{tour.icon}</span>
                        <span>
                          <span class="mobile-tour-name">{tour.label}</span>
                          <span class="mobile-tour-sub">{tour.sub}</span>
                        </span>
                      </a>
                    </li>
                  ))}
                  <li>
                    <a href="/tours" class="mobile-submenu-link mobile-submenu-link--all">Ver todos los tours →</a>
                  </li>
                </ul>
              )}
              {isRecursosLink && (
                <ul class="mobile-submenu">
                  {recursosSubmenu.map(({ href: subHref, label: subLabel }) => (
                    <li>
                      <a href={subHref} class="mobile-submenu-link">{subLabel}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="mobile-lang">
      {langSwitcher.map(({ href, code, label }) => (
        <a href={href} class:list={['lang-btn', { 'lang-btn--active': lang === code.toLowerCase() }]} title={label}>
          {code}
        </a>
      ))}
    </div>

    <a
      href="https://wa.me/51999999999"
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-wa-btn"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      Contactar por WhatsApp
    </a>
  </div>
</header>

<style>
  /* ─── Base header ─────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 500;
    background: rgba(8, 22, 12, 0.97);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(201, 148, 26, 0.18);
    transition: background 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-block: 0.75rem;
  }

  /* ─── Logo ────────────────────────────────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    mix-blend-mode: screen;
    filter: brightness(1.2) contrast(1.1);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-title {
    font-size: 0.67rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold-pale, #d4a843);
    font-family: var(--font-body, sans-serif);
    font-weight: 400;
    opacity: 0.8;
  }

  .logo-sub {
    font-size: 1.1rem;
    font-family: var(--font-heading, serif);
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.03em;
  }

  /* ─── Desktop nav ─────────────────────────────────────────────────── */
  .header-nav { flex: 1; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    justify-content: center;
  }

  .nav-item { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.72rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    border-radius: 5px;
    transition: color 0.2s, background 0.2s;
    letter-spacing: 0.025em;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-gold-light, #f0c050);
    background: rgba(201, 148, 26, 0.1);
  }

  /* Chevron indicator for dropdowns */
  .nav-chevron {
    font-size: 0.75rem;
    opacity: 0.5;
    transform: rotate(90deg);
    display: inline-block;
    transition: transform 0.2s;
  }

  .nav-item--has-submenu:hover .nav-chevron,
  .nav-item--has-submenu.is-active .nav-chevron {
    transform: rotate(-90deg);
    opacity: 0.9;
  }

  /* ─── Generic dropdown base ───────────────────────────────────────── */
  .nav-submenu {
    position: absolute;
    left: 0;
    top: calc(100% + 0.4rem);
    background: rgba(10, 26, 14, 0.98);
    border: 1px solid rgba(201, 148, 26, 0.2);
    border-radius: 10px;
    display: none;
    z-index: 30;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }

  /* Bridge pseudo-element to prevent accidental close */
  .nav-submenu::before {
    content: '';
    position: absolute;
    top: -14px;
    left: 0;
    width: 100%;
    height: 14px;
  }

  .nav-item--has-submenu:hover .nav-submenu,
  .nav-item--has-submenu:focus-within .nav-submenu,
  .nav-item--has-submenu.is-active .nav-submenu {
    display: block;
  }

  /* ─── Tours dropdown ──────────────────────────────────────────────── */
  .tours-dropdown {
    min-width: 320px;
  }

  .tours-dropdown-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem 0.5rem;
    border-bottom: 1px solid rgba(201, 148, 26, 0.12);
  }

  .tours-dropdown-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-light, #f0c050);
    opacity: 0.85;
  }

  .tours-dropdown-all {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
  }

  .tours-dropdown-all:hover {
    color: var(--color-gold-light, #f0c050);
  }

  .tours-list {
    list-style: none;
