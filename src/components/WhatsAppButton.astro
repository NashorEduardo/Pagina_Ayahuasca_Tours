---
// src/components/WhatsAppButton.astro
// Floating WhatsApp CTA button

interface Props {
  phone?: string;
  message?: string;
}

const {
  phone   = '51999999999',
  message = 'Hola, me interesa conocer más sobre sus retiros de ayahuasca.',
} = Astro.props;

const waURL = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  id="whatsapp-float"
  href={waURL}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-float"
  aria-label="Contáctanos por WhatsApp"
  title="Chatea con nosotros en WhatsApp"
>
  <!-- WhatsApp SVG icon -->
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.122.557 4.113 1.527 5.845L.073 23.203a.75.75 0 0 0 .903.962l5.534-1.451A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.878 0-3.645-.52-5.153-1.422l-.367-.217-3.803.998.998-3.803-.217-.367A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
  </svg>
  <span class="wa-label">WhatsApp</span>
</a>

<style>
  .wa-float {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    color: #fff;
    padding: 0.875rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 250ms ease, box-shadow 250ms ease;
    animation: waEntrance 0.6s 1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .wa-float:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 8px 30px rgba(37, 211, 102, 0.60);
    color: #fff;
  }

  .wa-float:active {
    transform: scale(0.97);
  }

  .wa-label {
    font-size: 0.9rem;
  }

  @keyframes waEntrance {
    from { opacity: 0; transform: translateY(20px) scale(0.8); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Pulse ring */
  .wa-float::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    background: rgba(37, 211, 102, 0.3);
    animation: pulseRing 2.5s infinite;
  }

  @keyframes pulseRing {
    0%   { transform: scale(1); opacity: 0.6; }
    70%  { transform: scale(1.18); opacity: 0; }
    100% { transform: scale(1.18); opacity: 0; }
  }

  @media (max-width: 480px) {
    .wa-float { bottom: 1.25rem; right: 1.25rem; padding: 0.75rem; }
    .wa-label { display: none; }
  }
</style>
