---
// src/components/RetiroCard.astro

interface Props {
  title: string;
  duration: number;
  includes: string[];
  description: string;
  icon?: string;
  badge?: string;
  waText?: string;
}

const {
  title,
  duration,
  includes,
  description,
  icon = '🌿',
  badge,
  waText,
} = Astro.props;

const defaultWaText = `Hola, me interesa el retiro: ${title}. ¿Podrían darme más información?`;
const wa = `https://wa.me/51999999999?text=${encodeURIComponent(waText ?? defaultWaText)}`;
---

<article class="retiro-card card" aria-label={`Retiro: ${title}`}>
  {badge && (
    <div class="retiro-badge">
      <span class="badge badge--gold">{badge}</span>
    </div>
  )}

  <div class="retiro-icon" aria-hidden="true">{icon}</div>

  <div class="retiro-body">
    <h3 class="retiro-title">{title}</h3>
    <p class="retiro-description">{description}</p>

    <!-- Meta -->
    <div class="retiro-meta">
      <div class="retiro-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span><strong>{duration}</strong> días</span>
      </div>
    </div>

    <!-- Includes -->
    <div class="retiro-includes">
      <span class="includes-label">¿Qué incluye?</span>
      <ul class="includes-list" aria-label={`Qué incluye el retiro ${title}`}>
        {includes.map(item => (
          <li class="includes-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
              <path d="M5 13l4 4L19 7"/>
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- CTA -->
  <a
    href={wa}
    target="_blank"
    rel="noopener noreferrer"
    class="retiro-cta btn btn--whatsapp"
    aria-label={`Reservar retiro: ${title} por WhatsApp`}
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z M12 0C5.373 0 0 5.373 0 12c0 2.122.557 4.113 1.527 5.845L.073 23.203a.75.75 0 0 0 .903.962l5.534-1.451A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.878 0-3.645-.52-5.153-1.422l-.367-.217-3.803.998.998-3.803-.217-.367A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
    </svg>
    Reservar por WhatsApp
  </a>
</article>

<style>
  .retiro-card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--color-white);
    border: 1px solid rgba(45,106,63,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .retiro-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(45,106,63,0.2);
  }

  .retiro-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 1;
  }

  .retiro-icon {
    font-size: 3rem;
    padding: 1.75rem 2rem 0;
    display: block;
    transition: transform 0.3s ease;
  }

  .retiro-card:hover .retiro-icon { transform: scale(1.1); }

  .retiro-body {
    padding: 1.25rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .retiro-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-jungle-deep);
    margin-bottom: 0.6rem;
  }

  .retiro-description {
    font-size: 0.875rem;
    color: var(--color-text-mid);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .retiro-meta {
    display: flex;
    gap: 1.5rem;
    padding: 0.875rem 0;
    border-top: 1px solid rgba(45,106,63,0.08);
    border-bottom: 1px solid rgba(45,106,63,0.08);
    margin-bottom: 1.25rem;
  }

  .retiro-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-text-mid);
  }

  .retiro-meta-item svg { color: var(--color-jungle-light); }
  .retiro-meta-item strong { color: var(--color-jungle-deep); }

  .includes-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }

  .includes-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .includes-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-text-mid);
  }

  .includes-item svg { color: var(--color-jungle-light); flex-shrink: 0; }

  .retiro-cta {
    margin: 0 2rem 2rem;
    justify-content: center;
    width: calc(100% - 4rem);
  }
</style>
