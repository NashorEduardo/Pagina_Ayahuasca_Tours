---
// src/components/Services.astro

const services = [
  {
    image: '/img/real/ayahuasca_ceremony.png',
    title: 'Retiro 1 Día Quillarumiyo',
    description: 'Nuestra experiencia introductoria con inmersión completa en la selva, ceremonias nocturnas y purificación.',
    features: ['Evaluación médica', 'Ceremonia de noche', 'Desplazamiento'],
  },
  {
    image: '/img/real/plant_diet.png',
    title: 'Retiro de 3 Días',
    description: 'Inmersión inicial a la medicina sagrada para tratar afecciones emocionales y purificar el cuerpo y espíritu profundamente.',
    features: ['2 ceremonias nocturnas', 'Baño florecimiento', 'Alojamiento incl.'],
  },
  {
    image: '/img/real/ayahuasca_ceremony.png',
    title: 'Retiro de 7 Días',
    description: 'Transformación espiritual completa con múltiples ceremonias y retiros de soledad en la profunda inmersión de la amazonía.',
    features: ['3 ceremonias', 'Dieta estricta', 'Consultas maestro'],
  },
  {
    image: '/img/real/san_pedro.png',
    title: 'Ceremonia San Pedro (Andes)',
    description: 'Expansión de consciencia diurna guiada por maestros andinos, en conexión profunda con las apus y la madre tierra.',
    features: ['Entorno majestuoso', 'Reconexión natural', '1 día completo'],
  },
  {
    image: '/img/real/plant_diet.png',
    title: 'Dieta de Plantas Maestras',
    description: 'Retiro prolongado consumiendo extractos puros de bobinsana o noya rao en estricta soledad para aprendizajes chamánicos.',
    features: ['Retiros de 14+ días', 'Aislamiento', 'Enseñanza profunda'],
  },
  {
    image: '/img/real/jungle.png',
    title: 'Retiro en Pareja',
    description: 'Curen heridas relacionales y reconstruyan el vínculo amoroso usando el poder revelador y compasivo de las plantas.',
    features: ['Terapia compartida', 'Cabaña privada', 'Maestro asignado'],
  },
];
---

<section id="servicios" class="section section--cream">
  <div class="container">
    <div class="section-header reveal">
      <div class="ornament">
        <span class="ornament-text">Nuestros Servicios</span>
      </div>
      <h2>Experiencias que Transforman</h2>
      <div class="divider-gold"></div>
      <p class="section-subtitle">
        Cada servicio está diseñado con respeto, seguridad y profundo conocimiento ancestral
      </p>
    </div>

    <div class="services-grid">
      {services.map((service, index) => (
        <article
          class="service-card reveal"
          style={`animation-delay: ${index * 0.1}s`}
          aria-label={service.title}
        >
          <div class="service-image-wrapper">
            <img src={service.image} alt={service.title} class="service-image" />
          </div>
          <div class="service-content">
            <h3 class="service-title">{service.title}</h3>
          <p class="service-description">{service.description}</p>
          <ul class="service-features" aria-label={`Características de ${service.title}`}>
            {service.features.map(feature => (
              <li class="service-feature">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                {feature}
              </li>
            ))}
            </ul>
            <a
              href={`https://wa.me/51999999999?text=${encodeURIComponent(`Hola, me interesa el servicio: ${service.title}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="service-cta"
              aria-label={`Consultar por WhatsApp sobre ${service.title}`}
              title={`Consultar sobre ${service.title}`}
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.487-1.761-1.66-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .service-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden; /* allows image border radius to work */
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(45,106,63,0.08);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(45,106,63,0.2);
  }
  
  .service-image-wrapper {
    height: 200px;
    width: 100%;
    overflow: hidden;
  }
  
  .service-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .service-card:hover .service-image {
    transform: scale(1.05);
  }
  
  .service-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .service-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-jungle-deep);
    margin-bottom: 0.75rem;
  }

  .service-description {
    font-size: 0.9rem;
    color: var(--color-text-mid);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  
  /* Make sure the SVGs render properly */
  :global(.service-svg) {
    width: 32px;
    height: 32px;
    color: var(--color-gold);
    display: inline-block;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .service-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-jungle-light);
    font-weight: 500;
  }

  .service-feature svg {
    color: var(--color-jungle-light);
    flex-shrink: 0;
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: #25d366;
    color: #fff;
    border-radius: 50%;
    text-decoration: none;
    transition: transform var(--transition-fast), background-color var(--transition-fast);
    align-self: flex-start;
    margin-top: auto;
  }

  .service-cta:hover {
    transform: scale(1.1);
    background-color: #20bd5a;
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
