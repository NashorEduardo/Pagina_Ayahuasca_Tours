---
// src/pages/retiros/[slug].astro
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

export async function getStaticPaths() {
  const retiroEntries = await getCollection('tours');
  return retiroEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const {
  title,
  description,
  image,
  price,
  duration,
  availability,
  frequency,
  difficulty,
  includes,
  excludes,
  itinerary,
  gallery,
  videoUrl,
  faq,
  whatsapp = '51999999999',
} = entry.data;
---

<Layout
  title={`${title} | Ayahuasca Cusco`}
  description={description ?? 'Retiro espiritual en la Amazonía Peruana.'}
  lang="es"
>
  <Header />

  <!-- ══════════════════════════════════
       HERO
  ══════════════════════════════════ -->
  <section class="hero">
    <img src={image} alt={title} class="hero__bg" />
    <div class="hero__dust"></div>
    <div class="hero__gradient"></div>

    <!-- Partícula decorativa -->
    <div class="hero__orb"></div>

    <div class="hero__content">
      <nav class="crumb">
        <a href="/">Inicio</a><span>·</span>
        <a href="/retiros">Retiros</a><span>·</span>
        <span class="crumb__cur">{title}</span>
      </nav>

      <div class="hero__glyph" aria-hidden="true">✦</div>
      <h1 class="hero__title">{title}</h1>
      {description && <p class="hero__sub">{description}</p>}

      <div class="hero__pills">
        {duration     && <span class="pill">{duration}</span>}
        {difficulty   && <span class="pill">{difficulty}</span>}
        {availability && <span class="pill">{availability}</span>}
      </div>

      <div class="hero__cta-row">
        <div class="hero__price-block">
          <span class="hero__price-from">desde</span>
          <span class="hero__price">${price}</span>
          <span class="hero__price-pp">/ persona</span>
        </div>
        <a href="#reserva" class="btn-primary">Reservar experiencia</a>
      </div>
    </div>

    <div class="hero__scroll-hint" aria-hidden="true">
      <span>Descubrir</span>
      <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
        <path d="M6 1v18M1 14l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════
       NAV STICKY
  ══════════════════════════════════ -->
  <nav class="snav">
    <div class="snav__inner">
      <a href="#descripcion" class="snav__a">Descripción</a>
      {itinerary?.length  > 0 && <a href="#itinerario" class="snav__a">Itinerario</a>}
      {(includes || excludes)  && <a href="#incluye"    class="snav__a">Incluye</a>}
      {gallery?.length    > 0 && <a href="#galeria"    class="snav__a">Galería</a>}
      {faq?.length        > 0 && <a href="#faq"        class="snav__a">FAQ</a>}
      <a href="#reserva" class="snav__a snav__a--cta">Reservar ↗</a>
    </div>
  </nav>

  <!-- ══════════════════════════════════
       DESCRIPCIÓN
  ══════════════════════════════════ -->
  <section id="descripcion" class="s-desc reveal">
    <div class="container">

      <div class="s-desc__grid">
        <!-- Texto -->
        <div class="s-desc__main">
          <p class="eyebrow">La experiencia</p>
          {description && <p class="lead-text">{description}</p>}
          <div class="prose"><Content /></div>
        </div>

        <!-- Stats flotantes -->
        <aside class="s-desc__aside">
          <div class="aside-card">
            <div class="aside-card__deco" aria-hidden="true">◈</div>
            {availability && (
              <div class="aside-stat">
                <span class="aside-stat__val">{availability}</span>
                <span class="aside-stat__key">Disponibilidad</span>
              </div>
            )}
            {duration && (
              <div class="aside-stat">
                <span class="aside-stat__val">{duration}</span>
                <span class="aside-stat__key">Duración</span>
              </div>
            )}
            {frequency && (
              <div class="aside-stat">
                <span class="aside-stat__val">{frequency}</span>
                <span class="aside-stat__key">Frecuencia</span>
              </div>
            )}
            {difficulty && (
              <div class="aside-stat">
                <span class="aside-stat__val">{difficulty}</span>
                <span class="aside-stat__key">Nivel</span>
              </div>
            )}
            <a href="#reserva" class="aside-cta">Reservar ahora</a>
          </div>
        </aside>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════
       ITINERARIO
  ══════════════════════════════════ -->
  {itinerary && itinerary.length > 0 && (
    <section id="itinerario" class="s-itin reveal">
      <div class="container">
        <p class="eyebrow eyebrow--light">El camino</p>
        <h2 class="section-title section-title--light">Tu viaje sagrado</h2>

        <div class="itin-list">
          {itinerary.map((item, index) => (
            <div class="itin-item">
              <div class="itin-item__marker">
                <span class="itin-item__day">{String(item.day).padStart(2,'0')}</span>
                <span class="itin-item__line"></span>
              </div>
              <div class="itin-item__body">
                <h3 class="itin-item__title">{item.title}</h3>
                {item.description && <p class="itin-item__desc">{item.description}</p>}
                {item.activities && (
                  <ul class="itin-item__acts">
                    {item.activities.map(act => <li>{act}</li>)}
                  </ul>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════
       INCLUYE / NO INCLUYE
  ══════════════════════════════════ -->
  {(includes || excludes) && (
    <section id="incluye" class="s-includes reveal">
      <div class="container">
        <p class="eyebrow">Lo que llevas</p>
        <h2 class="section-title">¿Qué incluye?</h2>

        <div class="inc-grid">
          {includes && (
            <div class="inc-col">
              <p class="inc-head inc-head--yes">Incluido</p>
              <ul class="inc-list">
                {includes.map(item => <li>{item}</li>)}
              </ul>
            </div>
          )}
          {excludes && (
            <div class="inc-col">
              <p class="inc-head inc-head--no">No incluido</p>
              <ul class="inc-list inc-list--no">
                {excludes.map(item => <li>{item}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════
       GALERÍA
  ══════════════════════════════════ -->
  {gallery && gallery.length > 0 && (
    <section id="galeria" class="s-gal reveal">
      <div class="container">
        <p class="eyebrow eyebrow--light">Imágenes</p>
        <h2 class="section-title section-title--light">Galería</h2>
      </div>

      <div class="gal-mosaic">
        {gallery.map((img, i) => (
          <div class={`gal-cell gal-cell--${(i % 5) + 1}`} onclick={`openLb(${i})`}>
            <img src={img} alt={`${title} ${i + 1}`} loading="lazy" />
            <div class="gal-cell__over">
              <span class="gal-cell__plus">+</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════
       FAQ
  ══════════════════════════════════ -->
  {faq && faq.length > 0 && (
    <section id="faq" class="s-faq reveal">
      <div class="container">
        <p class="eyebrow">Respuestas</p>
        <h2 class="section-title">Preguntas frecuentes</h2>

        <div class="faq-list">
          {faq.map((item, index) => (
            <div class="faq-item" data-index={String(index)}>
              <button class="faq-btn faq-trigger" data-index={String(index)}>
                <span class="faq-btn__num">{String(index + 1).padStart(2, '0')}</span>
                <span class="faq-btn__q">{item.question}</span>
                <span class="faq-btn__ico faq-ico">+</span>
              </button>
              <div class="faq-ans faq-answer">
                <p>{item.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════
       RESERVA
  ══════════════════════════════════ -->
  <section id="reserva" class="s-reserva reveal">
    <div class="s-reserva__bg-text" aria-hidden="true">RESERVA</div>
    <div class="container">
      <div class="res-wrap">

        <div class="res-left">
          <p class="eyebrow eyebrow--light">Empieza ahora</p>
          <h2 class="res-title">Transforma<br/><em>tu vida</em></h2>
          <p class="res-price">desde <strong>${price}</strong><br/><span>por persona</span></p>
          <p class="res-note">Cupos limitados · Respuesta en &lt;24 h</p>

          <div class="res-trust">
            <span>🌿 Facilitadores certificados</span>
            <span>🔒 Reserva segura</span>
            <span>✨ Ceremonia auténtica</span>
          </div>
        </div>

        <div class="res-form">
          <div class="form-row">
            <input type="text" placeholder="Nombre"   class="inp" />
            <input type="text" placeholder="Apellido" class="inp" />
          </div>
          <input type="email" placeholder="Email *"   class="inp inp--full" />
          <input type="tel"   placeholder="WhatsApp"  class="inp inp--full" />
          <select class="inp inp--full">
            <option value="" disabled selected>¿Cuántas personas?</option>
            <option>1 persona</option>
            <option>2 personas</option>
            <option>3–5 personas</option>
            <option>Grupo (+5)</option>
          </select>
          <textarea
            placeholder="Cuéntanos tu intención para este retiro…"
            rows="3"
            class="inp inp--full inp--ta"
          ></textarea>
          <button class="btn-submit">Enviar consulta</button>
          <a
            href={`https://wa.me/${whatsapp}?text=${encodeURIComponent('Hola, me interesa el retiro: ' + title)}`}
            class="btn-wa"
            target="_blank" rel="noopener noreferrer"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contactar por WhatsApp
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  {gallery && gallery.length > 0 && (
    <div id="lb" class="lb lb--hidden">
      <button id="lb-close" class="lb__close">×</button>
      <button id="lb-prev"  class="lb__nav lb__nav--l">‹</button>
      <img    id="lb-img"   class="lb__img" src="" alt="" />
      <button id="lb-next"  class="lb__nav lb__nav--r">›</button>
      <span   id="lb-cnt"   class="lb__cnt"></span>
    </div>
  )}

  <!-- ══ SCRIPTS ══ -->
  <script define:vars={{ galleryImages: gallery ?? [] }}>
    let cur = 0;
    function openLb(i) {
      cur = i;
      const lb  = document.getElementById('lb');
      const img = document.getElementById('lb-img');
      const cnt = document.getElementById('lb-cnt');
      if (!lb || !img) return;
      img.src = galleryImages[cur];
      if (cnt) cnt.textContent = `${cur + 1} / ${galleryImages.length}`;
      lb.classList.remove('lb--hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeLb() {
      document.getElementById('lb')?.classList.add('lb--hidden');
      document.body.style.overflow = '';
    }
    function navLb(d) {
      cur = (cur + d + galleryImages.length) % galleryImages.length;
      const img = document.getElementById('lb-img');
      const cnt = document.getElementById('lb-cnt');
      if (img) img.src = galleryImages[cur];
      if (cnt) cnt.textContent = `${cur + 1} / ${galleryImages.length}`;
    }
    document.getElementById('lb-close')?.addEventListener('click', closeLb);
    document.getElementById('lb')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeLb(); });
    document.getElementById('lb-next')?.addEventListener('click', () => navLb(1));
    document.getElementById('lb-prev')?.addEventListener('click', () => navLb(-1));
    document.addEventListener('keydown', e => {
      if (document.getElementById('lb')?.classList.contains('lb--hidden')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowRight') navLb(1);
      if (e.key === 'ArrowLeft')  navLb(-1);
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // FAQ
      document.querySelectorAll('.faq-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const idx  = (trigger as HTMLElement).dataset.index!;
          const item = document.querySelector(`.faq-item[data-index="${idx}"]`);
          if (!item) return;
          const ans  = item.querySelector('.faq-answer') as HTMLElement;
          const ico  = item.querySelector('.faq-ico')    as HTMLElement;
          const open = ans.style.maxHeight && ans.style.maxHeight !== '0px';
          document.querySelectorAll('.faq-item').forEach(el => {
            const a = el.querySelector('.faq-answer') as HTMLElement;
            const i = el.querySelector('.faq-ico')    as HTMLElement;
            if (a) a.style.maxHeight = '0px';
            if (i) i.textContent = '+';
          });
          if (!open) { ans.style.maxHeight = ans.scrollHeight + 'px'; ico.textContent = '−'; }
        });
      });

      // Reveal
      const obs = new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); } }),
        { threshold: 0.07 }
      );
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    });
  </script>

  <Footer />
  <WhatsAppButton />
</Layout>

<!-- ══════════════════════════════════════
     ESTILOS
══════════════════════════════════════ -->
<style is:global>

/* ── Tokens ── */
:root {
  --ink:       #0b1a0e;
  --forest:    #132b1a;
  --moss:      #1e3d28;
  --gold:      #c9963a;
  --gold-pale: #e8c97a;
  --cream:     #f2ede4;
  --warm:      #ede8df;
  --muted:     #7a8c7c;
  --border:    rgba(180,165,130,0.25);
  --serif:     'Playfair Display', Georgia, serif;
  --sans:      'DM Sans', 'Helvetica Neue', sans-serif;
}

/* ── Reveal ── */
.reveal { opacity:0; transform:translateY(32px); transition: opacity .7s ease, transform .7s ease; }
.reveal.revealed { opacity:1; transform:none; }

/* ── Container ── */
.container { max-width:1160px; margin:0 auto; padding:0 2rem; }

/* ══════════════════
   HERO
══════════════════ */
.hero {
  position:relative;
  height:100vh; min-height:640px;
  display:flex; align-items:flex-end;
  overflow:hidden;
}
.hero__bg {
  position:absolute; inset:0;
  width:100%; height:100%; object-fit:cover;
  animation: heroZoom 12s ease-out forwards;
}
@keyframes heroZoom { from{transform:scale(1.08)} to{transform:scale(1)} }

/* Dust overlay — textura granulada */
.hero__dust {
  position:absolute; inset:0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  opacity:.35; pointer-events:none;
}
.hero__gradient {
  position:absolute; inset:0;
  background:
    linear-gradient(to top, rgba(8,18,10,.92) 0%, rgba(8,18,10,.2) 50%, transparent 100%),
    linear-gradient(to right, rgba(8,18,10,.4) 0%, transparent 50%);
}

/* Orb decorativo */
.hero__orb {
  position:absolute; top:18%; right:12%;
  width:320px; height:320px; border-radius:50%;
  background: radial-gradient(circle, rgba(201,150,58,.18) 0%, transparent 70%);
  animation: orbPulse 6s ease-in-out infinite;
  pointer-events:none;
}
@keyframes orbPulse { 0%,100%{transform:scale(1);opacity:.7} 50%{transform:scale(1.15);opacity:1} }

.hero__content {
  position:relative; z-index:2;
  width:100%; max-width:1160px; margin:0 auto;
  padding:0 2rem 4.5rem;
}

/* Breadcrumb */
.crumb {
  display:flex; gap:.5rem; align-items:center;
  font-family:var(--sans); font-size:.68rem;
  text-transform:uppercase; letter-spacing:.15em;
  color:rgba(255,255,255,.35); margin-bottom:1.5rem;
}
.crumb a { color:inherit; text-decoration:none; transition:color .2s; }
.crumb a:hover { color:var(--gold-pale); }
.crumb__cur { color:var(--gold-pale); }

/* Glyph */
.hero__glyph {
  font-size:1.5rem; color:var(--gold);
  opacity:.7; margin-bottom:.75rem;
  animation: glyphSpin 20s linear infinite;
  display:inline-block;
}
@keyframes glyphSpin { to{transform:rotate(360deg)} }

/* Título */
.hero__title {
  font-family:var(--serif);
  font-size: clamp(3rem,8vw,6.5rem);
  font-weight:700; color:#fff;
  line-height:.95; letter-spacing:-.02em;
  margin:0 0 1.25rem; max-width:18ch;
  text-shadow:0 4px 40px rgba(0,0,0,.4);
}

/* Subtítulo */
.hero__sub {
  font-family:var(--sans);
  font-size:1rem; color:rgba(255,255,255,.6);
  max-width:52ch; line-height:1.65;
  margin:0 0 2rem;
  font-style:italic;
}

/* Pills */
.hero__pills { display:flex; flex-wrap:wrap; gap:.5rem; margin-bottom:2.5rem; }
.pill {
  font-family:var(--sans); font-size:.68rem;
  text-transform:uppercase; letter-spacing:.12em;
  color:rgba(255,255,255,.65);
  border:1px solid rgba(255,255,255,.18);
  backdrop-filter:blur(6px);
  padding:.3rem 1rem; border-radius:999px;
}

/* CTA row */
.hero__cta-row {
  display:flex; align-items:center; gap:2.5rem; flex-wrap:wrap;
}
.hero__price-block { display:flex; align-items:baseline; gap:.4rem; }
.hero__price-from, .hero__price-pp {
  font-family:var(--sans); font-size:.75rem;
  color:rgba(255,255,255,.4);
}
.hero__price {
  font-family:var(--serif); font-size:3rem;
  font-weight:700; color:var(--gold); line-height:1;
}

/* Primary button */
.btn-primary {
  font-family:var(--sans); font-size:.78rem;
  font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  color:var(--ink);
  background:linear-gradient(135deg, var(--gold-pale), var(--gold));
  padding:.9rem 2.25rem; border-radius:.6rem;
  text-decoration:none;
  box-shadow:0 8px 32px rgba(201,150,58,.35);
  transition: transform .2s, box-shadow .2s;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 12px 40px rgba(201,150,58,.5); }

/* Scroll hint */
.hero__scroll-hint {
  position:absolute; bottom:2rem; left:50%; transform:translateX(-50%);
  display:flex; flex-direction:column; align-items:center; gap:.5rem;
  color:rgba(255,255,255,.35);
  font-family:var(--sans); font-size:.65rem;
  text-transform:uppercase; letter-spacing:.15em;
  animation:scrollBounce 2.5s ease-in-out infinite;
}
@keyframes scrollBounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

/* ══════════════════
   STICKY NAV
══════════════════ */
.snav {
  position:sticky; top:0; z-index:50;
  background:rgba(8,18,10,.96);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.snav__inner {
  max-width:1160px; margin:0 auto; padding:0 2rem;
  display:flex; height:54px; align-items:center;
  overflow-x:auto; gap:0;
}
.snav__a {
  font-family:var(--sans); font-size:.72rem;
  font-weight:600; text-transform:uppercase; letter-spacing:.09em;
  color:rgba(255,255,255,.45); text-decoration:none;
  padding:0 1.25rem; height:100%;
  display:flex; align-items:center;
  border-bottom:2px solid transparent;
  white-space:nowrap;
  transition:color .2s, border-color .2s;
}
.snav__a:hover { color:#fff; border-bottom-color:var(--gold); }
.snav__a--cta { color:var(--gold); margin-left:auto; }
.snav__a--cta:hover { color:var(--gold-pale); }

/* ══════════════════
   SHARED
══════════════════ */
.eyebrow {
  font-family:var(--sans); font-size:.65rem;
  text-transform:uppercase; letter-spacing:.2em;
  color:var(--gold); margin-bottom:.75rem;
  display:flex; align-items:center; gap:.75rem;
