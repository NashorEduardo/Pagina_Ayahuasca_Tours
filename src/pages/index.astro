---
// src/pages/index.astro — Home Page

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import GoogleMap from '../components/GoogleMap.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// Obtener tours dinámicamente desde la colección
const tours = await getCollection('tours');

const blogPosts = [
  {
    title: '¿Qué es la Ayahuasca? Historia y Orígenes Ancestrales',
    slug: 'que-es-la-ayahuasca',
    excerpt: 'La ayahuasca es una bebida psicoactiva preparada con plantas de la Amazonía. Te contamos su historia, sus componentes y su papel en las culturas indígenas.',
    date: '2024-10-15',
    category: 'Medicina',
    readTime: 8,
  },
  {
    title: 'Cómo Prepararse para una Ceremonia de Ayahuasca',
    slug: 'como-prepararse-ceremonia',
    excerpt: 'La preparación es tan importante como la ceremonia misma. Aprende sobre la dieta, las intenciones y el estado mental ideal para una experiencia transformadora.',
    date: '2024-11-02',
    category: 'Guía',
    readTime: 6,
  },
  {
    title: 'Integración Post-Ceremonia: El Verdadero Trabajo Comienza Después',
    slug: 'integracion-post-ceremonia',
    excerpt: 'Las experiencias con plantas maestras revelan mucho. La integración es el proceso de aplicar esas enseñanzas en tu vida cotidiana.',
    date: '2024-12-01',
    category: 'Integración',
    readTime: 7,
  },
];
---

<Layout
  title="Spirit of Amazonas | Retiros de Ayahuasca en la Amazonía Peruana"
  description="Centro de retiros de ayahuasca con facilitadores certificados en Iquitos, Perú. Ceremonias sagradas, retiros de 7 días, sanación espiritual en la Amazonía. Reserva tu experiencia transformadora."
  lang="es"
>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <Hero />

    <!-- Tours Destacados (dinámicos desde content/tours) -->
    <section id="tours-destacados" class="section section--dark">
      <div class="container">
        <div class="section-header reveal">
          <div class="ornament">
            <span class="ornament-text" style="color:var(--color-gold-pale)">Nuestras Experiencias</span>
          </div>
          <h2 style="color:var(--color-white)">Tours Disponibles</h2>
          <div class="divider-gold"></div>
          <p class="section-subtitle">Explora nuestros tours ancestrales en el Valle Sagrado</p>
        </div>
        
        <div class="tours-grid">
          {tours.map((tour, i) => (
            <a 
              href={`/tours/${tour.id}`} 
              class="tour-card reveal"
              style={`animation-delay:${i * 0.12}s`}
            >
              <div class="tour-card__image">
                <img src={tour.data.image || '/img/real/jungle.png'} alt={tour.data.title} loading="lazy" />
                <div class="tour-card__overlay"></div>
              </div>
              <div class="tour-card__content">
                <div class="tour-card__badges">
                  {tour.data.duration && <span class="tour-badge">{tour.data.duration}</span>}
                  {tour.data.difficulty && <span class="tour-badge tour-badge--level">{tour.data.difficulty}</span>}
                </div>
                <h3 class="tour-card__title">{tour.data.title}</h3>
                <p class="tour-card__desc">{tour.data.description}</p>
                <div class="tour-card__footer">
                  <span class="tour-card__price">
                    <span class="tour-card__from">desde</span>
                    ${tour.data.price}
                    <span class="tour-card__pp">/ persona</span>
                  </span>
                  <span class="tour-card__cta">Ver detalles →</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div style="text-align:center; margin-top:2.5rem">
          <a href="/retiros" class="btn btn--primary">Ver Catálogo Completo</a>
        </div>
      </div>
    </section>

    <!-- Services -->
    <Services />

    <!-- Testimonials -->
    <Testimonials />

    <!-- Blog Preview -->
    <section id="blog-home" class="section section--cream">
      <div class="container">
        <div class="section-header reveal">
          <div class="ornament">
            <span class="ornament-text">Conocimiento Ancestral</span>
          </div>
          <h2>Artículos del Blog</h2>
          <div class="divider-gold"></div>
          <p class="section-subtitle">Aprende sobre medicina ancestral, preparación e integración</p>
        </div>
        <div class="grid-3">
          {blogPosts.map((post, i) => (
            <div class="reveal" style={`animation-delay:${i*0.12}s`}>
              <BlogCard {...post} />
            </div>
          ))}
        </div>
        <div style="text-align:center; margin-top:2.5rem">
          <a href="/blog" class="btn btn--primary">Ver Todos los Artículos</a>
        </div>
      </div>
    </section>

    <!-- FAQ snippet -->
    <FAQ />

    <!-- Contact + Map -->
    <section id="contacto-home" class="section section--dark">
      <div class="container">
        <div class="section-header reveal">
          <div class="ornament">
            <span class="ornament-text" style="color:var(--color-gold-pale)">Contáctanos</span>
          </div>
          <h2 style="color:var(--color-white)">¿Lista para Tu Retiro?</h2>
          <div class="divider-gold"></div>
          <p class="section-subtitle">Escríbenos y te respondemos en menos de 24 horas</p>
        </div>
        <div class="contact-home-grid">
          <div class="reveal">
            <!-- Google Maps embed -->
            <GoogleMap />
          </div>
          <div class="reveal" style="animation-delay:0.2s">
            <div class="contact-info-cards">
              <div class="contact-info-card">
                <span class="cic-icon">📞</span>
                <div>
                  <strong>Teléfono</strong>
                  <a href="tel:+51999999999">+51 999 999 999</a>
                </div>
              </div>
              <div class="contact-info-card">
                <span class="cic-icon">✉️</span>
                <div>
                  <strong>Email</strong>
                  <a href="mailto:info@spiritofamazonas.com">info@spiritofamazonas.com</a>
                </div>
              </div>
              <div class="contact-info-card">
                <span class="cic-icon">📍</span>
                <div>
                  <strong>Ubicación</strong>
                  <span>Iquitos, Loreto, Perú</span>
                </div>
              </div>
              <div class="contact-info-card">
                <span class="cic-icon">🕐</span>
                <div>
                  <strong>Horario de Atención</strong>
                  <span>Lun–Dom · 8:00–20:00 (PET)</span>
                </div>
              </div>
            </div>
            <a
              href="https://wa.me/51999999999?text=Hola%2C%20me%20interesa%20información%20sobre%20sus%20retiros"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--whatsapp"
              style="width:100%; justify-content:center; margin-top:1.5rem"
            >
              Escribir por WhatsApp Ahora
            </a>
            <a
              href="/contacto"
              class="btn btn--outline"
              style="width:100%; justify-content:center; margin-top:0.75rem"
            >
              Ir al Formulario de Contacto
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
  <WhatsAppButton />
</Layout>

<style>
  /* Tours Grid */
  .tours-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .tour-card {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .tour-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    border-color: rgba(201,150,58,0.3);
  }

  .tour-card__image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .tour-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .tour-card:hover .tour-card__image img {
    transform: scale(1.08);
  }

  .tour-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,26,15,0.8) 0%, transparent 60%);
  }

  .tour-card__content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tour-card__badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tour-badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: rgba(201,150,58,0.15);
    color: var(--color-gold-pale);
    border: 1px solid rgba(201,150,58,0.25);
  }

  .tour-badge--level {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    border-color: rgba(255,255,255,0.12);
  }

  .tour-card__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .tour-card__desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tour-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .tour-card__price {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .tour-card__from,
  .tour-card__pp {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
  }

  .tour-card__cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gold-pale);
    transition: color 0.2s;
  }

  .tour-card:hover .tour-card__cta {
    color: var(--color-gold);
  }

  /* Contact home */
  .contact-home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .contact-info-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
  }
  .cic-icon { font-size: 1.5rem; flex-shrink: 0; }
  .contact-info-card strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gold-pale);
    margin-bottom: 0.2rem;
  }
  .contact-info-card a,
  .contact-info-card span {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
  }
  .contact-info-card a:hover { color: var(--color-gold-light); }

  @media (max-width: 900px) {
    .contact-home-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .tours-grid { grid-template-columns: 1fr; }
  }
</style>
